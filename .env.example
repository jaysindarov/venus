# ─────────────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────────────
APP_NAME="VisionaryAI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=visionaryai
DB_USERNAME=sail
DB_PASSWORD=password

# ─────────────────────────────────────────────────
# CACHE & SESSIONS
# ─────────────────────────────────────────────────
CACHE_STORE=redis
# CACHE_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

# ─────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────────────
# MAIL (Mailpit for local dev)
# ─────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@visionaryai.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production mail (Mailgun)
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_SECRET=key-...
# MAILGUN_ENDPOINT=api.mailgun.net

# ─────────────────────────────────────────────────
# FILE STORAGE (AWS S3 / Cloudflare R2)
# ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=visionaryai-media
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

# ─────────────────────────────────────────────────
# STRIPE (BILLING)
# ─────────────────────────────────────────────────
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
CASHIER_CURRENCY=usd

STRIPE_PRICE_BASIC_MONTHLY=price_
STRIPE_PRICE_BASIC_YEARLY=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_YEARLY=price_
STRIPE_PRICE_CREATOR_MONTHLY=price_
STRIPE_PRICE_CREATOR_YEARLY=price_

# ──────────────────────────────────────────────────────────────────
# AI PROVIDERS — Laravel AI SDK (laravel/ai)
# ──────────────────────────────────────────────────────────────────
AI_PROVIDER=openai

# Tier 1: SDK-backed image providers
OPENAI_API_KEY=sk-
GEMINI_API_KEY=
XAI_API_KEY=

# Tier 2: Custom providers (future — uncomment when adding)
# REPLICATE_API_TOKEN=r8_
# FAL_API_KEY=
# STABILITY_API_KEY=sk-

# ─────────────────────────────────────────────────
# AUTH (OAUTH)
# ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL="${APP_URL}/auth/google/callback"

# ─────────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=

# ─────────────────────────────────────────────────
# CONTENT MODERATION
# ─────────────────────────────────────────────────
MODERATION_ENABLED=true

# ─────────────────────────────────────────────────
# MEILISEARCH (Phase 2)
# ─────────────────────────────────────────────────
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=

# ─────────────────────────────────────────────────
# VITE
# ─────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
